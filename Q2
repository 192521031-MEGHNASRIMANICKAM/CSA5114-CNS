#include <stdio.h>
#include <string.h>
int main(){
    char text[100], key[27];
    int i;
    printf("Enter the plaintext (uppercase only): ");
    scanf("%s", text);
    printf("Enter the 26-letter substitution key: ");
    scanf("%s", key);
    for(i = 0; text[i] != '\0'; i++){
        if(text[i] >= 'A' && text[i] <= 'Z'){
            text[i] = key[text[i] - 'A'];
        }
    }
    printf("Encrypted text: %s\n", text);
    return 0;
}
